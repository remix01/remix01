# ══════════════════════════════════════════════════════════
# LiftGO .gitignore
# ══════════════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js ───────────────────────────────────────────────
.next/
out/
build/
dist/

# ── Environment files (SECURITY — never commit secrets!) ──
.env
.env.local
.env.*.local
.env.*.secret
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.staging.local
.env.vercel-sync-tmp
.env.sentry-build-plugin

# ── Testing ───────────────────────────────────────────────
coverage/
.nyc_output/
jest-results.json
test-results/
playwright-report/
playwright/.cache/

# ── TypeScript ────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ────────────────────────────────────────────────
.vercel/

# ── Supabase ──────────────────────────────────────────────
supabase/.temp/
supabase/.branches/

# ── Sentry ────────────────────────────────────────────────
.sentryclirc

# ── Logs ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
lerna-debug.log*
build-output.log

# ── OS files ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Editors ───────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Certificates & keys ───────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx

# ── Archives ──────────────────────────────────────────────
*.tar.gz
*.zip
*.rar
*.7z

# ── Misc ──────────────────────────────────────────────────
.cache/
.parcel-cache/
.turbo/
.husky/_/
tmp/
temp/
