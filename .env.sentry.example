# ============================================================================
# SENTRY ENTERPRISE MONITORING - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in the actual values
# Last Updated: April 2026

# ============================================================================
# SENTRY CORE CONFIGURATION
# ============================================================================

# Sentry DSN for server-side error tracking
SENTRY_DSN=https://[key]@[organization].ingest.sentry.io/[project]

# Sentry DSN for client-side (browser) error tracking
NEXT_PUBLIC_SENTRY_DSN=https://[key]@[organization].ingest.sentry.io/[project]

# Node environment (development, staging, production)
NODE_ENV=production

# Vercel deployment environment
VERCEL_ENV=production

# Git commit SHA for release tracking
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=abc123def456

# ============================================================================
# SLACK INTEGRATION
# ============================================================================

# Critical alerts channel (production issues, payment errors)
# Create incoming webhook: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_CRITICAL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX

# Engineering alerts channel (API errors, performance issues)
SLACK_WEBHOOK_ENGINEERING=https://hooks.slack.com/services/T00000000/B00000001/XXXXXXXXXXXXXXXXXXXX

# Business alerts channel (signups, conversions, transactions)
SLACK_WEBHOOK_BUSINESS=https://hooks.slack.com/services/T00000000/B00000002/XXXXXXXXXXXXXXXXXXXX

# ============================================================================
# EMAIL ALERTING
# ============================================================================

# On-call engineer email address
EMAIL_ONCALL=oncall@liftgo.dev

# Engineering team email
EMAIL_TEAM=engineering@liftgo.dev

# Business team email
EMAIL_BUSINESS=business@liftgo.dev

# ============================================================================
# JIRA INTEGRATION
# ============================================================================

# Jira API URL
JIRA_API_URL=https://liftgo.atlassian.net/rest/api/3

# Jira API token (create in: Jira Settings > Security > API tokens)
# Get it from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-api-token-here

# Jira project key
JIRA_PROJECT_KEY=LIFTGO

# Jira username (usually your email)
JIRA_USERNAME=your-email@liftgo.dev

# ============================================================================
# GITHUB INTEGRATION
# ============================================================================

# GitHub personal access token
# Create at: https://github.com/settings/tokens
# Scopes needed: repo, workflow, write:discussion
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub repository owner
GITHUB_OWNER=remix01

# GitHub repository name
GITHUB_REPO=remix01

# ============================================================================
# PAGERDUTY INTEGRATION
# ============================================================================

# PagerDuty integration key for event routing
# Get from: PagerDuty > Services > [Service] > Integrations
PAGERDUTY_INTEGRATION_KEY=your-pagerduty-integration-key

# PagerDuty API key (optional, for incident management)
PAGERDUTY_API_KEY=your-pagerduty-api-key

# PagerDuty service ID
PAGERDUTY_SERVICE_ID=your-service-id

# ============================================================================
# PERFORMANCE THRESHOLDS
# ============================================================================

# Alert if API response time exceeds this (milliseconds)
API_PERFORMANCE_THRESHOLD_MS=5000

# Alert if database query exceeds this (milliseconds)
DB_QUERY_THRESHOLD_MS=2000

# Alert if page load exceeds this (milliseconds)
PAGE_LOAD_THRESHOLD_MS=5000

# Alert if error rate exceeds this percentage
ERROR_RATE_THRESHOLD_PERCENT=5

# ============================================================================
# SENTRY SAMPLING RATES (Production Values)
# ============================================================================

# Transaction sampling rate (0.0 - 1.0)
# 0.1 = 10% of transactions sampled (recommended for production)
SENTRY_TRACES_SAMPLE_RATE=0.2

# Session replay sampling rate for normal sessions (0.0 - 1.0)
SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.1

# Session replay sampling rate when errors occur (0.0 - 1.0)
# Always set to 1.0 to capture all error sessions
SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1.0

# ============================================================================
# FEATURE FLAGS & DEPLOYMENT
# ============================================================================

# Enable/disable feature flags
FEATURE_NEW_TASK_UI=false
FEATURE_NEW_TASK_UI_ROLLOUT_PERCENT=10
FEATURE_IMPROVED_MATCHING=true
FEATURE_IMPROVED_MATCHING_ROLLOUT_PERCENT=100
FEATURE_VIDEO_DIAGNOSIS=false
FEATURE_VIDEO_DIAGNOSIS_ROLLOUT_PERCENT=0

# ============================================================================
# OPTIONAL: ADVANCED MONITORING
# ============================================================================

# Custom Sentry ingest endpoint (for self-hosted Sentry)
SENTRY_INGEST_URL=

# Custom release tracking webhook
SENTRY_WEBHOOK_URL=

# Enable detailed debug logging
DEBUG_SENTRY=false

# ============================================================================
# SUPABASE DATABASE MONITORING
# ============================================================================

# Monitor slow queries (milliseconds)
SLOW_QUERY_THRESHOLD_MS=1000

# Track all database errors
TRACK_DB_ERRORS=true

# ============================================================================
# STRIPE PAYMENT MONITORING
# ============================================================================

# Track Stripe webhook events
TRACK_STRIPE_EVENTS=true

# Alert on failed payments
ALERT_FAILED_PAYMENTS=true

# ============================================================================
# NOTES
# ============================================================================
#
# 1. Get Sentry DSN:
#    - Go to: sentry.io/settings/[org]/projects/[project]/keys/dsn/
#
# 2. Create Slack Webhooks:
#    - Go to: https://api.slack.com/messaging/webhooks
#    - Create 3 separate webhooks for different severity levels
#
# 3. GitHub Token Permissions:
#    - repo: full control of private repositories
#    - workflow: update GitHub Actions workflows
#    - write:discussion: post pull request comments
#
# 4. Jira Setup:
#    - Enable API tokens: https://id.atlassian.com/manage-profile/security/api-tokens
#    - Create API token and add to JIRA_API_TOKEN
#
# 5. PagerDuty Integration:
#    - Go to: Services > [Service] > Integrations
#    - Copy the Sentry integration key
#
# 6. Sampling Rates:
#    - Development: Use 1.0 (100%) for full debugging
#    - Staging: Use 0.5 (50%) to catch issues
#    - Production: Use 0.1-0.2 (10-20%) to manage quota
#
# 7. Keep this file secure:
#    - Never commit actual tokens
#    - Rotate tokens regularly
#    - Use strong, unique tokens for each service
#
