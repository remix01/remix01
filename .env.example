# ══════════════════════════════════════════════════════════════
# LiftGO Environment Variables
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# Anthropic API Configuration
# Get from: https://console.anthropic.com/
# ──────────────────────────────────────────────────────────────

# Anthropic API Key - for AI agent matchmaking
# Get from: Anthropic Console > API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────────────────────
# Supabase Configuration
# Get from: https://supabase.com/dashboard/project/_/settings/api
# ──────────────────────────────────────────────────────────────

# Public URL - safe to expose in client-side code
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon key - safe for client-side, RLS policies are enforced
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyj...

# Service role key - NEVER expose to client! Bypasses RLS. Use only server-side.
# Get from: Settings > API > service_role key (click "Reveal")
SUPABASE_SERVICE_ROLE_KEY=eyJ...

#──────────────────────────────────────────────────────────────
# Upstash QStash Configuration — Job Queue
# Get from: https://console.upstash.com/
# ──────────────────────────────────────────────────────────────

# QStash API Token - for enqueueing jobs
# Get from: Upstash Console > QStash > Tokens > Create
QSTASH_TOKEN=your_qstash_token_here

# QStash Signing Keys - for verifying webhook signatures
# Get from: Upstash Console > QStash > Signing Keys
QSTASH_CURRENT_SIGNING_KEY=your_current_signing_key_here
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key_here

# ────────────────────────────────────────────────────────────── 
# Stripe Configuration
# Get from: https://dashboard.stripe.com/test/apikeys
# ──────────────────────────────────────────────────────────────

# Secret key - server-side only, NEVER expose to client
STRIPE_SECRET_KEY=sk_test_51...

# Publishable key - safe for client-side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51...

# Optional: explicit Stripe Product/Price IDs used by /cenik and checkout flow
# Keep these in sync with your Stripe dashboard (test vs live mode).
STRIPE_START_PRODUCT_ID=prod_...
STRIPE_START_PRICE_ID=price_...
STRIPE_PRO_PRODUCT_ID=prod_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ELITE_PRODUCT_ID=prod_...
STRIPE_ELITE_PRICE_ID=price_...
STRIPE_CUSTOMER_PREMIUM_PRODUCT_ID=prod_...
STRIPE_CUSTOMER_PREMIUM_PRICE_ID=price_...

# Backward-compatible aliases (optional)
NEXT_PUBLIC_STRIPE_PRODUCT_ID_START=prod_...
NEXT_PUBLIC_STRIPE_PRICE_ID_START=price_...
NEXT_PUBLIC_STRIPE_PRODUCT_ID_PRO=prod_...
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO=price_...
NEXT_PUBLIC_STRIPE_PRODUCT_ID_ELITE=prod_...
NEXT_PUBLIC_STRIPE_PRICE_ID_ELITE=price_...
NEXT_PUBLIC_STRIPE_PRODUCT_ID_CUSTOMER_PREMIUM=prod_...
NEXT_PUBLIC_STRIPE_PRICE_ID_CUSTOMER_PREMIUM=price_...

# Webhook secret - for verifying Stripe webhook signatures
# Get from: Developers > Webhooks > Add endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Platform commission percentage (10 = 10%, 15 = 15%)
STRIPE_PLATFORM_COMMISSION_PCT=10

# ──────────────────────────────────────────────────────────────
# Twilio Configuration
# Get from: https://console.twilio.com/
# ──────────────────────────────────────────────────────────────

# Account SID - Get from: Console > Account Info
TWILIO_ACCOUNT_SID=AC...

# Auth Token - Get from: Console > Account Info (click "View")
TWILIO_AUTH_TOKEN=your-auth-token

# Conversations Service SID
# Get from: Console > Conversations > Services > Create/Select Service
TWILIO_CONVERSATIONS_SERVICE_SID=IS...

# Proxy phone numbers - comma-separated list of Twilio numbers
# Get from: Console > Phone Numbers > Buy a number
# Format: +38651111111,+38651111112,+38651111113
TWILIO_PROXY_NUMBERS=+38651000001,+38651000002

# ──────────────────────────────────────────────────────────────
# NextAuth Configuration
# ──────────────────────────────────────────────────────────────

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-min-32-chars

# Production URL - change in production deployment
NEXTAUTH_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────
# Web Push Notifications (VAPID)
# Generate with: npx web-push generate-vapid-keys
# ──────────────────────────────────────────────────────────────

# VAPID Public Key (exposed to client)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# VAPID Private Key (server-side only)
VAPID_PRIVATE_KEY=your-vapid-private-key

# VAPID Subject (your contact email)
VAPID_SUBJECT=mailto:info@liftgo.net

# ──────────────────────────────────────────────────────────────
# Google Calendar Configuration
# Get from: https://console.cloud.google.com/
# ──────────────────────────────────────────────────────────────

# Google OAuth Client ID
# 1. Create a new project in Google Cloud Console
# 2. Enable Google Calendar API
# 3. Create OAuth 2.0 credentials (Desktop app)
# 4. Copy the Client ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Google OAuth Client Secret
# Copy from the OAuth credentials JSON file
GOOGLE_CLIENT_SECRET=your-client-secret

# Google API Key — for code-review MCP server and Google APIs
# Get from: Google Cloud Console > APIs & Services > Credentials
GOOGLE_API_KEY=your-google-api-key

# ──────────────────────────────────────────────────────────────
# Google Maps
# Get from: Google Cloud Console > APIs & Services > Credentials
# Enable: Maps JavaScript API, Geocoding API, Places API, Directions API
# ──────────────────────────────────────────────────────────────

# Separate Maps API key (restrict to Maps APIs only — principle of least privilege)
GOOGLE_MAPS_API_KEY=your-maps-api-key

# ──────────────────────────────────────────────────────────────
# Google Workspace CLI MCP (@googleworkspace/cli)
# Covers: Gmail, Drive, Calendar, Sheets, Docs
# Setup: npx @googleworkspace/cli auth   (runs OAuth flow, saves credentials file)
# Get Client ID/Secret from: Google Cloud Console > OAuth 2.0 Client IDs
# Add redirect URI: http://localhost:3000/auth/callback
# ──────────────────────────────────────────────────────────────

# Reuses GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET from above
# Path to the credentials JSON saved after running: npx @googleworkspace/cli auth
GOOGLE_WORKSPACE_CREDENTIALS_FILE=/home/user/.config/googleworkspace/credentials.json

# ──────────────────────────────────────────────────────────────
# Google Search (Custom Search API)
# Get from: https://programmablesearchengine.google.com/
# Create a Programmable Search Engine → copy the cx ID
# ──────────────────────────────────────────────────────────────

GOOGLE_SEARCH_ENGINE_ID=your-cx-search-engine-id

# ──────────────────────────────────────────────────────────────
# Google Analytics MCP (analytics-mcp — official Google, Python/pipx)
# Requires: pipx installed (pip install pipx)
# Service account: Google Cloud Console > IAM > Service Accounts
# Grant role: roles/analyticsreporting.viewer on your GA4 property
# ──────────────────────────────────────────────────────────────

# Path to service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/home/user/.config/gcloud/service-account.json

# Google Cloud project ID (from Google Cloud Console dashboard)
GOOGLE_PROJECT_ID=your-gcp-project-id

# GA4 Property ID (from Google Analytics > Admin > Property Settings)
GA4_PROPERTY_ID=properties/123456789

# ─────────────���────────────────────────────────────────────────
# Application Configuration
# ──────────────────────────────────────────────────────────────

# Public URL - used in emails, OAuth redirects, etc.
NEXT_PUBLIC_URL=http://localhost:3000

# Public app URL (used for emails, redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret - protects cron job endpoints from unauthorized access
# Generate with: openssl rand -hex 32
CRON_SECRET=dolg-nakljucen-niz-vsaj-32-znakov

# Admin email - receives alerts and violation reports
ADMIN_EMAIL=admin@liftgo.net

# Slack webhook for alerts
# Get from: Slack → Settings → Apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ───────���──────────────────────────────────────────────────────
# Email Configuration (Transactional emails via Resend)
# Get from: https://resend.com/api-keys
# ──────────────────────────────────────────────────────────────

# Resend API Key - for inquiry confirmations, partner notifications
# Get from: Resend Dashboard > API Keys
RESEND_API_KEY=re_...

# From email address - must be verified domain in Resend
NEXT_PUBLIC_FROM_EMAIL=noreply@liftgo.net

# ────────────────────────────────────────��─────────────────────
# Supabase Custom SMTP (for auth emails)
# Configure in: Supabase Dashboard > Authentication > Email Templates
# Settings > SMTP Settings
# ──────────────────────────────────────────────────────────────
# Host: smtp.resend.com
# Port: 465
# User: resend
# Pass: [use RESEND_API_KEY above]
# Sender email: noreply@liftgo.net
# This is configured in Supabase dashboard, NOT in code.
# ──────────────────────────────────────────────────────────────

# Legacy SMTP (optional fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@liftgo.net

# ──────────────────────────────────────────────────────────────
# Development/Production Toggle
# ──────────────────────────────────────────────────────────────

NODE_ENV=development

# ──────────────────────────────────────────────────────────────
# Stripe Connect & Escrow Configuration
# ──────────────────────────────────────────────────────────────

# Stripe Connect — platforma account za izplačila obrtnikom
# Ustvari na: dashboard.stripe.com → Connect → Settings
STRIPE_PLATFORM_FEE_PERCENT=10        # START provizija (%)
STRIPE_PRO_FEE_PERCENT=5              # PRO provizija (%)

# ── ESCROW NASTAVITVE
ESCROW_AUTO_RELEASE_DAYS=7            # Po koliko dneh se escrow auto-sprosti

# ──────────────────────────────────────────────────────────────
# Migration Settings
# ──────────────────────────────────────────────────────────────

# Batch size for partner migration (number of partners per batch)
MIGRATION_BATCH_SIZE=50

# ──────────────────────────────────────────────────────────────
# Google Analytics
# Get from: https://analytics.google.com/
# ──────────────────────────────────────────────────────────────

# Google Analytics Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ──────────────────────────────────────────────────────────────
# MCP (Model Context Protocol) Configuration
# For Claude Desktop, Claude Code CLI, and AI development
# ──────────────────────────────────────────────────────────────

# GitHub (for MCP integration)
# Get from: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxx

# Vercel (for MCP deployment tools)
# Get from: Vercel → Settings → Tokens
VERCEL_TOKEN=xxxxxxxxxxxx

# Sentry (for MCP error tracking)
# Get from: https://sentry.io → Account → API Tokens
SENTRY_AUTH_TOKEN=xxxxxxxxxxxx
SENTRY_ORG=liftgo
SENTRY_PROJECT=liftgo-nextjs

# Upstash Redis (for MCP cache/queue operations)
# Get from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxx

# Brave Search (for MCP web search - optional)
# Get from: https://api.search.brave.com/
BRAVE_API_KEY=xxxxxxxxxxxx

# PostgreSQL Direct Connection (for MCP postgres server)
# Format: postgresql://postgres:PASSWORD@db.REGION.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:xxxxxxxxxxxx@db.whabaeatixtymbccwigu.supabase.co:5432/postgres
