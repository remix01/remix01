# ════════════════════════════════════════════════════════════════════════════════
# LiftGO Production Environment Variables - Docker Compose Setup
# ════════════════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────────────────────
# Application Environment
# ────────────────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_URL=https://your-domain.com
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=your-super-secret-key-min-32-chars

# ────────────────────────────────────────────────────────────────────────────────
# Supabase Configuration
# Get from: https://supabase.com/dashboard/project/_/settings/api
# ────────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.REGION.supabase.co:5432/postgres

# ────────────────────────────────────────────────────────────────────────────────
# Object Storage (MinIO / S3-compatible)
# STORAGE_PROVIDER=minio   → self-hosted MinIO (Docker Compose)
# STORAGE_PROVIDER=supabase → Supabase Storage (default, no MinIO needed)
#
# Quick-start (local dev):
#   1. Run:  docker compose -f docker-compose.yml -f docker-compose.dev.yml up
#   2. Open: http://localhost:9001  (admin / minioadmin_change_me_in_production)
#   3. Set:  STORAGE_PROVIDER=minio in your .env
#
# Generate strong credentials:
#   openssl rand -base64 32
# ────────────────────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=supabase

# MinIO root credentials (docker-compose only – never use these in the app)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_change_me_in_production

# MinIO application service account (used by Next.js, NOT root credentials)
# Create via MinIO Console → Identity → Service Accounts
# or the minio-init.sh script will create it automatically.
MINIO_ACCESS_KEY=liftgo-app
MINIO_SECRET_KEY=change_me_to_a_strong_random_secret_min_32_chars

# Internal Docker network endpoint (used by Next.js server-side)
MINIO_ENDPOINT=http://minio:9000

# Public URL for browser access to uploaded files
# Local dev:   http://localhost:9000
# Production:  https://storage.liftgo.net  (Nginx proxy to MinIO)
MINIO_PUBLIC_URL=http://localhost:9000

# S3 region – MinIO ignores this but the AWS SDK requires it
MINIO_REGION=us-east-1

# ────────────────────────────────────────────────────────────────────────────────
# Redis Configuration (Rate Limiting, Caching)
# ────────────────────────────────────────────────────────────────────────────────
# For Docker Compose with local Redis:
REDIS_PASSWORD=your-secure-redis-password-min-16-chars
UPSTASH_REDIS_REST_URL=http://redis:6379
UPSTASH_REDIS_REST_TOKEN=
# For Upstash Cloud (production):
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxx
# REDIS_PASSWORD= (not needed for Upstash)

# ────────────────────────────────────────────────────────────────────────────────
# Upstash QStash (Job Queue)
# Get from: https://console.upstash.com/
# ────────────────────────────────────────────────────────────────────────────────
QSTASH_TOKEN=your_qstash_token_here
QSTASH_CURRENT_SIGNING_KEY=your_current_signing_key_here
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key_here

# ────────────────────────────────────────────────────────────────────────────────
# Stripe Configuration
# Get from: https://dashboard.stripe.com/
# ────────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_51...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_51...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATFORM_COMMISSION_PCT=10
STRIPE_PLATFORM_FEE_PERCENT=10
STRIPE_PRO_FEE_PERCENT=5

# Stripe Product/Price IDs
STRIPE_START_PRODUCT_ID=prod_...
STRIPE_START_PRICE_ID=price_...
STRIPE_PRO_PRODUCT_ID=prod_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ELITE_PRODUCT_ID=prod_...
STRIPE_ELITE_PRICE_ID=price_...
STRIPE_CUSTOMER_PREMIUM_PRODUCT_ID=prod_...
STRIPE_CUSTOMER_PREMIUM_PRICE_ID=price_...

# ────────────────────────────────────────────────────────────────────────────────
# Anthropic API (AI Agents)
# Get from: https://console.anthropic.com/
# ────────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ────────────────────────────────────────────────────────────────────────────────
# Twilio Configuration (Messaging)
# Get from: https://console.twilio.com/
# ────────────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_CONVERSATIONS_SERVICE_SID=IS...
TWILIO_PROXY_NUMBERS=+38651000001,+38651000002

# ────────────────────────────────────────────────────────────────────────────────
# Email Configuration (Transactional emails via Resend)
# Get from: https://resend.com/api-keys
# ────────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@liftgo.net
RESEND_WEBHOOK_SECRET=whsec_...

# SMTP Fallback (Legacy)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@liftgo.net

# ────────────────────────────────────────────────────────────────────────────────
# Google Configuration
# Get from: https://console.cloud.google.com/
# ────────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_MAPS_API_KEY=AIza...
GOOGLE_SEARCH_ENGINE_ID=012345678901234567890:abcde_fghij
GOOGLE_PROJECT_ID=your-gcp-project-id

# ────────────────────────────────────────────────────────────────────────────────
# Web Push Notifications (VAPID)
# Generate with: npx web-push generate-vapid-keys
# ────────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:info@liftgo.net

# ────────────────────────────────────────────────────────────────────────────────
# Observability & Monitoring
# ────────────────────────────────────────────────────────────────────────────────

# Sentry (Error tracking)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_RELEASE=

# PostHog (Product Analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# LangSmith (LLM tracing)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=pr-your-project-name

# ────────────────────────────────────────────────────────────────────────────────
# Application Configuration
# ────────────────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@liftgo.net
CRON_SECRET=dolg-nakljucen-niz-vsaj-32-znakov
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
MIGRATION_BATCH_SIZE=50
ESCROW_AUTO_RELEASE_DAYS=7

# ────────────────────────────────────────────────────────────────────────────────
# MCP (Model Context Protocol) Integration
# Used for AI development and external tools
# ────────────────────────────────────────────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxx
VERCEL_TOKEN=xxxxxxxxxxxx
SENTRY_AUTH_TOKEN=xxxxxxxxxxxx
SENTRY_ORG=liftgo
SENTRY_PROJECT=liftgo-nextjs
BRAVE_API_KEY=xxxxxxxxxxxx
