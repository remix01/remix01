# Build-time environment variables skeleton
# Used only during Docker image build
# Do NOT put real secrets here - set them as GitHub Secrets
# and inject dynamically in GitHub Actions (see .github/workflows/)

NODE_ENV=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
QSTASH_TOKEN=
REDIS_PASSWORD=
