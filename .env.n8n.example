# ══════════════════════════════════════════════════════════════
# N8N Webhook Configuration for LiftGO
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# N8N Server Configuration
# ──────────────────────────────────────────────────────────────

# Base URL for n8n webhooks (where n8n is hosting)
# For cloud: https://app.n8n.cloud (managed by n8n)
# For self-hosted: https://n8n.yourdomain.com
N8N_WEBHOOK_BASE=https://n8n.liftgo.net/webhook

# Shared secret for signing webhook requests
# Generate: openssl rand -hex 32
N8N_WEBHOOK_SECRET=your-webhook-secret-min-32-chars

# ──────────────────────────────────────────────────────────────
# N8N Internal Configuration (only needed if self-hosting)
# ──────────────────────────────────────────────────────────────

# N8N host (domain where n8n runs)
N8N_HOST=n8n.liftgo.net

# Use HTTPS for n8n
N8N_PROTOCOL=https

# URL where n8n is accessible
N8N_WEBHOOK_URL=https://n8n.liftgo.net/webhook

# Database for n8n workflows and execution history
# SQLite (local): sqlite://n8n.sqlite
# PostgreSQL: postgresql://user:password@host:port/database
N8N_DB_URL=postgresql://user:password@db.liftgo.net:5432/n8n

# N8N secret for encryption
N8N_ENCRYPTION_KEY=your-encryption-key-min-32-chars

# ──────────────────────────────────────────────────────────────
# Connections for N8N Workflows
# (These are credentials n8n uses to connect to external services)
# ──────────────────────────────────────────────────────────────

# Supabase (n8n will query database for tasks, ponudbe, etc.)
# Format: postgresql://user:password@host:5432/postgres
N8N_SUPABASE_CONNECTION=postgresql://postgres:your-password@db.whabaeatixtymbccwigu.supabase.co:5432/postgres

# Stripe API Key (for managing payments and transfers)
# Get from: https://dashboard.stripe.com/test/apikeys
N8N_STRIPE_SECRET_KEY=sk_test_51xxx

# Resend API Key (for sending emails)
# Get from: https://resend.com/api-keys
N8N_RESEND_API_KEY=re_xxx

# Slack API Token (for admin alerts)
# Get from: https://api.slack.com/apps/ → OAuth Tokens
N8N_SLACK_BOT_TOKEN=xoxb-xxx

# Slack Channel ID for alerts
# Get channel ID: Right-click channel in Slack → Copy ID
N8N_SLACK_ALERTS_CHANNEL=C0XXXX

# ──────────────────────────────────────────────────────────────
# LiftGO Webhook Configuration
# (For webhooks sent BY LiftGO TO n8n)
# ──────────────────────────────────────────────────────────────

# Optional: API Key for n8n API access (if using n8n API calls)
# Get from: n8n Settings → API Keys
N8N_API_KEY=n8n_api_xxx

# Optional: API URL if using n8n API
N8N_API_URL=https://n8n.liftgo.net/api

# ──────────────────────────────────────────────────────────────
# LiftGO-Specific Webhook Configuration
# (Copy to main .env file)
# ──────────────────────────────────────────────────────────────

# From main .env file (copy these values)
N8N_WEBHOOK_BASE=https://n8n.liftgo.net/webhook
N8N_WEBHOOK_SECRET=your-webhook-secret-min-32-chars

# Optional: For job queue retries via Upstash QStash
QSTASH_TOKEN=your_qstash_token_here
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ──────────────────────────────────────────────────────────────
# Monitoring & Error Tracking
# ──────────────────────────────────────────────────────────────

# Sentry for error tracking
# Get from: https://sentry.io/settings/account/api/
SENTRY_AUTH_TOKEN=your_sentry_token

# ══════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ══════════════════════════════════════════════════════════════

# 1. Copy this file to .env.n8n
# 2. Fill in all values from your n8n instance and services
# 3. Copy n8n webhook values to main .env file:
#    - N8N_WEBHOOK_BASE
#    - N8N_WEBHOOK_SECRET
# 4. Deploy to production with these values

# For local development, use different n8n instance
# or test with ngrok tunnel:
# ngrok http 5678 (for local n8n)
# Then update N8N_WEBHOOK_BASE to ngrok URL

# ══════════════════════════════════════════════════════════════
